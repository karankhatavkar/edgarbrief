# Supabase: Dashboard → Project Settings → API
# Database: Dashboard → Project Settings → Database → Connection string

# --- Supabase (Auth + API) ---

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# --- Postgres (Alembic + direct DB access) ---

# Use the DIRECT connection (host: db.<ref>.supabase.co).
# Do NOT use the transaction pooler URL (pooler.supabase.com) — migrations require a session connection.
# URL-encode special characters in the password.
DATABASE_URL=postgresql://postgres:your-password@db.your-project-ref.supabase.co:5432/postgres

# --- Google Gemini (LLM + embeddings) ---

GEMINI_API_KEY=your-gemini-api-key
GEMINI_CHAT_MODEL=gemini-2.5-flash-lite
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_EMBEDDING_DIMENSIONS=768

# --- Server ---

# Comma-separated browser origins allowed to call the API (CORS).
# JSON-encoded list (required by pydantic-settings for list fields)
ALLOWED_ORIGINS=["http://localhost:5173"]

# --- Logging ---

# LOG_LEVEL: DEBUG | INFO | WARNING | ERROR. LOG_JSON: true for machine-parseable logs in prod.
LOG_LEVEL=INFO
LOG_JSON=false

# --- Demo cost controls (Phase B) ---

# Per-user LIFETIME token budget (never resets; exhausting it is permanent).
# Tokens are summed across every internal step of a turn. ~₹5 worth at a
# conservative gemini-flash-lite rate — verify against current pricing.
DEMO_USER_TOKEN_LIMIT=150000
# Distinct demo users allowed per calendar month (auto-resets on the 1st).
DEMO_MONTHLY_LIMIT=20
# Hard cap on a single Gemini answer's output tokens.
MAX_OUTPUT_TOKENS=1024
# Emails that bypass both limits — set to the owner's login email for testing.
# JSON-encoded list.
DEMO_EXEMPT_EMAILS=[]
