# Supabase: Dashboard → Project Settings → API
# Only public (browser-safe) values belong here — never the service_role key or database URL.

# --- Backend API ---

# Relative path: the app calls /api in both dev (Vite proxies it to the backend)
# and prod (FastAPI serves the build and the API from the same origin).
VITE_API_BASE_URL=/api

# --- Supabase (browser auth) ---

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
